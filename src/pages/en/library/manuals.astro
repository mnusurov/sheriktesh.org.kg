---
import { getCollection } from 'astro:content';
import PageLayout from '../../../layouts/PageLayout.astro';

export const prerender = true;

const lang = 'en';
const title = 'Training Manuals';
const pageTitle = 'Training Manuals';
const description = 'Training manuals — library of PA Counterpart-Sheriktesh';

const [category] = await getCollection('documents', (d) => d.data.category === 'manuals' && d.data.lang === lang);
---

<PageLayout title={title} lang={lang} pageTitle={pageTitle} description={description}>
  <div class="doc-list">
    {category.data.docs.map((doc) => (
      <div class="doc-item">
        {doc.cover && <img class="doc-thumb" src={doc.cover} alt="" />}
        <a href={`/assets/documents/${doc.pdf}`} target="_blank" class="doc-link">{doc.description}</a>
      </div>
    ))}
  </div>
</PageLayout>
