---
import PageLayout from '../../../layouts/PageLayout.astro';

export const prerender = true;

const lang = 'en';
const title = 'Training Manuals';
const pageTitle = 'Training Manuals';
---

<PageLayout title={title} lang={lang} pageTitle={pageTitle}>
  <div class="doc-list">
  <div class="doc-section-heading">Training for Human Rights Trainers. Facilitator's Manual.</div>
  <div class="doc-item"><a href="../books/CHRF-Manual-Fac-TOT1-English2001.pdf" target="_blank" class="doc-link">Book 1 - PDF 1.47 Mb</a></div>
  <div class="doc-item"><a href="../books/CHRF-Manual-Fac-TOT2-English2001.pdf" target="_blank" class="doc-link">Book 2 - PDF 1.16 Mb</a></div>
  <div class="doc-section-heading">Training for Human Rights Trainers. Participant's Manual.</div>
  <div class="doc-item"><a href="../books/CHRF-Manual-Par-TOT1-English2001.pdf" target="_blank" class="doc-link">Book 1 - PDF 1.29 Mb</a></div>
  <div class="doc-item"><a href="../books/CHRF-Manual-Par-TOT2-English2001.pdf" target="_blank" class="doc-link">Book 2 - PDF 1.06 Mb</a>
</PageLayout>
