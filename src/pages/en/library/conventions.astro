---
import PageLayout from '../../../layouts/PageLayout.astro';

export const prerender = true;

const lang = 'en';
const title = 'Conventions';
const pageTitle = 'Conventions';
---

<PageLayout title={title} lang={lang} pageTitle={pageTitle}>
  <p>International human rights conventions and treaties:</p>

  <ul>
    <li><a href="/documents/udhr_en.pdf" target="_blank">Universal Declaration of Human Rights</a> (PDF)</li>
    <li><a href="/documents/echr_en.pdf" target="_blank">European Convention on Human Rights</a> (PDF)</li>
    <li><a href="/documents/ecosoc_en.pdf" target="_blank">International Covenant on Economic, Social and Cultural Rights</a> (PDF)</li>
    <li><a href="/documents/cedaw_en.pdf" target="_blank">Convention on the Elimination of All Forms of Discrimination against Women (CEDAW)</a> (PDF)</li>
    <li><a href="/documents/crc_en.pdf" target="_blank">Convention on the Rights of the Child</a> (PDF)</li>
  </ul>
</PageLayout>
