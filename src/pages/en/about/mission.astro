---
import PageLayout from '../../../layouts/PageLayout.astro';

export const prerender = true;

const lang = 'en';
const title = 'Mission';
const pageTitle = 'Mission';
const description = 'Mission of PA Counterpart-Sheriktesh — promoting civil society development through capacity building';
---

<PageLayout title={title} lang={lang} pageTitle={pageTitle} description={description}>
  <p><strong>Mission of the organization:</strong></p>
      <p>From the moment of its establishment (January 2002) Public Association "Counterpart-Sheriktesh" has defined its mission as:</p>
      <p><em><strong>"Promotion of civil society development through capacity building of its actors in order to provide their active and efficient participation in decision making process and integration into the world community via training, informational support and mobilization of resources".</strong></em></p>
      <p>In order to comply with its mission Public Association "Counterpart-Sheriktesh" implements activities in the following areas:
      <ul>
      <li>Organization Development (OD)</li>
      <li>Training</li>
      <li>Representation/Contractual Services</li>
      <li>Information Support (Internet access, web site)</li>
      <li>Social Partnership</li>
      <li>Advocacy/Campaigns/Coalition Building</li>
      <li>Community Outreach</li>
      <li>Human Rights</li>
      </ul>
      </p>
</PageLayout>
