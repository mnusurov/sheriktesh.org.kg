---
import PageLayout from '../../../layouts/PageLayout.astro';

export const prerender = true;

const lang = 'en';
const title = 'Staff';
const pageTitle = 'Staff';
---

<PageLayout title={title} lang={lang} pageTitle={pageTitle}>
  <p>The staff of the Public Association «Counterpart-Sheriktesh» consists of qualified specialists in the fields of human rights, law, ecology, sociology and project management.</p>

  <h2>Management</h2>
  <p>The Executive Director and program department heads provide strategic and operational management of the organization's activities.</p>

  <h2>Staff Members</h2>
  <p>The organization employs lawyers, monitoring experts, trainers, project coordinators, public relations specialists and administrative personnel. Many staff members have many years of experience in the human rights field and have undergone specialized training.</p>

  <p>The organization also engages external experts and consultants for the implementation of individual projects and programs.</p>
</PageLayout>
