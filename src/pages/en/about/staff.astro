---
import PageLayout from '../../../layouts/PageLayout.astro';

export const prerender = true;

const lang = 'en';
const title = 'Staff';
const pageTitle = 'Staff';
---

<PageLayout title={title} lang={lang} pageTitle={pageTitle}>
  <div class="staff-grid">
  <div class="staff-card">
    <div class="staff-photo-placeholder" style="width:80px;height:106px;background:var(--border);border-radius:6px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:2rem;color:var(--text-light);">?</div>
    <div>
      <div class="staff-name">Nurdin Sattarov</div>
      <div class="staff-role">Executive Director
</PageLayout>
