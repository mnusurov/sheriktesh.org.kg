---
import { getCollection } from 'astro:content'
import PageLayout from '@/layouts/PageLayout.astro'

export const prerender = true;

const lang = 'en';
const staff = (await getCollection('staff', ({ data }) => data.lang === lang))
  .sort((a, b) => a.data.order - b.data.order)
---

<PageLayout title="Staff" lang={lang} pageTitle="Staff">
  <div class="staff-grid">
    {staff.map(({ data }) => (
      <div class="staff-card">
        {data.photo ? (
          <img src={data.photo} alt={data.title} />
        ) : (
          <div class="staff-photo-placeholder" style="width:80px;height:106px;background:var(--border);border-radius:6px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:2rem;color:var(--text-light);">?</div>
        )}
        <div>
          <div class="staff-name">{data.title}</div>
          <div class="staff-role">{data.role}</div>
        </div>
      </div>
    ))}
  </div>
</PageLayout>
