---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SidebarWidget from '../../components/SidebarWidget.astro';

export const prerender = true;

const lang = 'en';
const title = 'Home';
const description = 'Public Association Counterpart-Sheriktesh — civil society development and human rights protection in Kyrgyzstan';
---

<BaseLayout title={title} lang={lang} description={description}>
  <main class="content">
    <div class="container">
      <div class="content-wrap">
        <div class="content-main">
          <section class="hero">
            <h1>Public Association «Counterpart-Sheriktesh»</h1>
            <p class="hero-subtitle">Civil society development and human rights protection in Kyrgyzstan</p>
          </section>

          <p><strong>In 2026 the organization celebrates 24 years!</strong></p>
          <p>Counterpart-Sheriktesh is a registered NGO, established by civil society activists with the aim of building capacity of civil society organizations in Kyrgyzstan. From the outset, Counterpart-Sheriktesh capacity building support has included delivering training in basic modules, providing consultations in organizational development, and facilitation of information exchange between NGOs and community organizations.</p>
          <p>Counterpart-Sheriktesh has gradually been extending its services and has actively participated in the process of strengthening civic participation in decision-making and NGO capacity building through introducing new training modules, launching new services (advocacy, fostering social partnership, etc.) and expanding its clientele.</p>
          <p>Counterpart-Sheriktesh has taken part in the development of the National Poverty Reduction Strategy: two chapters concerning wide participation procedures and the NGO role in the implementation of the given strategy were developed by Counterpart-Sheriktesh staff.</p>

          <section class="about-section">
            <h2>About Us</h2>
            <p>Public Association "Counterpart-Sheriktesh" was founded in January 2002. The organization works in the field of strengthening civil society, protecting human rights, and democratic development of the Kyrgyz Republic.</p>
            <p>Our mission is to promote the building of a democratic, law-governed state, develop civil society institutions, and protect human and civil rights and freedoms.</p>
            <p>Over the years we have implemented dozens of projects aimed at monitoring human rights compliance, legal education of the population, development of local communities, and strengthening democratic institutions.</p>
          </section>

          <section class="activities-section">
            <h2>Main Areas of Activity</h2>
            <ul>
              <li>Human rights monitoring</li>
              <li>Legal education and training</li>
              <li>Civil society development</li>
              <li>Protection of vulnerable groups</li>
              <li>Environmental monitoring and protection</li>
            </ul>
          </section>
        </div>
        <aside class="content-sidebar">
          <SidebarWidget lang={lang} />
        </aside>
      </div>
    </div>
  </main>
</BaseLayout>
