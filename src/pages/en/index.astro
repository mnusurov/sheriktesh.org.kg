---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SidebarWidget from '../../components/SidebarWidget.astro';

export const prerender = true;

const lang = 'en';
const title = 'Home';
const description = 'Public Association Counterpart-Sheriktesh — civil society development and human rights protection in Kyrgyzstan';
---

<BaseLayout title={title} lang={lang} description={description}>
  <main class="content">
    <div class="container">
      <div class="content-wrap">
        <div class="content-main">
          <p><strong>In 2026 the organization celebrates 24 years!</strong></p>
          <p>Counterpart-Sheriktesh is registered NGO, established by civil society activists with aim to build capacity of civil society organizations in Kyrgyzstan. From the outset, Counterpart-Sheriktesh capacity building support has included delivering training in basic modules, providing consultations in organizational development, and facilitation of information exchange between NGOs and community organizations.</p>
          <p>Counterpart-Sheriktesh has gradually been extending its services and has actively participated in the process of strengthening civic participation in decision-making and NGO capacity building through introducing new training modules, launching new services (advocacy, fostering social partnership, etc.) and expanding its clientele.</p>
          <p>Counterpart-Sheriktesh has taken part in development of National Poverty Reduction Strategy: two chapters concerning wide participation procedures and NGO role in the implementation of the given strategy were developed by Counterpart-Sheriktesh staff.</p>
        </div>
        <aside class="content-sidebar">
          <SidebarWidget lang={lang} />
        </aside>
      </div>
    </div>
  </main>
</BaseLayout>
