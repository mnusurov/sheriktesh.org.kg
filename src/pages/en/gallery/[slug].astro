---
import { getCollection } from 'astro:content';
import PageLayout from '../../../layouts/PageLayout.astro';

export const prerender = true;

export async function getStaticPaths() {
  const entries = await getCollection('galleries', (e) => e.data.lang === 'en');
  return entries.map((e) => ({
    params: { slug: String(e.data.order) },
    props: { entry: e },
  }));
}

const { entry } = Astro.props;
const description = 'Photo gallery of PA Counterpart-Sheriktesh';
---

<PageLayout title={entry.data.title} lang={entry.data.lang} pageTitle={entry.data.title} description={description}>
  <div class="gallery-grid">
    {entry.data.images.map((img) => (
      <img src={img} alt="" />
    ))}
  </div>
</PageLayout>
