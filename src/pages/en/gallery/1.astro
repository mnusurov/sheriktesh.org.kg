---
import PageLayout from '../../../layouts/PageLayout.astro';

export const prerender = true;

const lang = 'en';
const title = 'National Conference on Social Partnership';
const pageTitle = 'National Conference on Social Partnership';
---

<PageLayout title={title} lang={lang} pageTitle={pageTitle}>
  <div class="gallery-grid">
    <img src="/assets/foto/event1.jpg" alt="Event 1" />
    <img src="/assets/foto/event2.jpg" alt="Event 2" />
    <img src="/assets/foto/event3.jpg" alt="Event 3" />
  </div>
</PageLayout>
