---
import PageLayout from '../../../layouts/PageLayout.astro';

export const prerender = true;

const lang = 'en';
const title = 'Final Round Table on AKDN Project';
const pageTitle = 'Final Round Table on AKDN Project';
---

<PageLayout title={title} lang={lang} pageTitle={pageTitle}>
  <div class="gallery-grid">
    <img src="/assets/foto/conf1.jpg" alt="Conference 1" />
    <img src="/assets/foto/conf2.jpg" alt="Conference 2" />
    <img src="/assets/foto/conf3.jpg" alt="Conference 3" />
  </div>
</PageLayout>
