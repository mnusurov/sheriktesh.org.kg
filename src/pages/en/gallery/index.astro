---
import { getCollection } from 'astro:content';
import PageLayout from '../../../layouts/PageLayout.astro';

export const prerender = true;

const lang = 'en';
const title = 'Photo Gallery';
const pageTitle = 'Photo Gallery';
const description = 'Photo gallery of PA Counterpart-Sheriktesh';

const galleries = (await getCollection('galleries', (g) => g.data.lang === lang))
  .sort((a, b) => a.data.order - b.data.order);
---

<PageLayout title={title} lang={lang} pageTitle={pageTitle} description={description}>
  <p>Photos of the organization's events and projects.</p>

  <div class="gallery-card-grid">
    {galleries.map((g) => (
      <a class="gallery-card" href={`/en/gallery/${g.data.order}`}>
        <img class="gallery-card-thumb" src={g.data.images[0]} alt="" />
        <div class="gallery-card-body">
          <h3>{g.data.title}</h3>
          <span class="gallery-card-count">{g.data.images.length} photos</span>
        </div>
      </a>
    ))}
  </div>
</PageLayout>
