---
import PageLayout from '../../../layouts/PageLayout.astro';

export const prerender = true;

const lang = 'en';
const title = 'Civil Society Development';
const pageTitle = 'Program 8: Civil Society Development';
---

<PageLayout title={title} lang={lang} pageTitle={pageTitle}>
  <p>The civil society development program is aimed at strengthening civil society institutions in Kyrgyzstan.</p>
  <p>The organization provides support to non-governmental organizations, initiative groups and civic activists.</p>
  <p>Training events, consultations are conducted, and methodological assistance is provided in the development and implementation of socially significant projects.</p>
</PageLayout>
