---
import PageLayout from '../../../layouts/PageLayout.astro';

export const prerender = true;

const lang = 'en';
const title = 'Election Monitoring';
const pageTitle = 'Program 11: Election Monitoring';
---

<PageLayout title={title} lang={lang} pageTitle={pageTitle}>
  <p>The election monitoring program is aimed at ensuring free and fair elections in the Kyrgyz Republic.</p>
  <p>The organization prepares independent observers, monitors the electoral process, analyzes compliance with electoral rights of citizens.</p>
  <p>Monitoring results are published in the form of reports and recommendations for improving electoral legislation.</p>
</PageLayout>
