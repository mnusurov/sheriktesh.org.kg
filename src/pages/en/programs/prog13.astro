---
import PageLayout from '../../../layouts/PageLayout.astro';

export const prerender = true;

const lang = 'en';
const title = 'Media Development';
const pageTitle = 'Program 13: Independent Media Development';
---

<PageLayout title={title} lang={lang} pageTitle={pageTitle}>
  <p>The independent media development program is aimed at supporting freedom of speech and developing independent journalism in Kyrgyzstan.</p>
  <p>The organization conducts trainings for journalists, provides legal support to media representatives, and promotes professional journalism standards.</p>
  <p>Projects are implemented to protect the rights of journalists and develop digital media.</p>
</PageLayout>
