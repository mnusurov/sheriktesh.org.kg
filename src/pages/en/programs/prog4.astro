---
import PageLayout from '../../../layouts/PageLayout.astro';

export const prerender = true;

const lang = 'en';
const title = "Women's Rights Protection";
const pageTitle = 'Program 4: Women\'s Rights Protection';
---

<PageLayout title={title} lang={lang} pageTitle={pageTitle}>
  <p>The women's rights protection program is aimed at ensuring gender equality and protecting women's rights in Kyrgyzstan.</p>
  <p>The program implements projects to prevent gender-based violence, support women in difficult life situations, and increase women's economic independence.</p>
  <p>The organization conducts information campaigns and educational activities on gender equality issues.</p>
</PageLayout>
