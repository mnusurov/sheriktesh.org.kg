---
import { getCollection } from 'astro:content';
import PageLayout from '../../../layouts/PageLayout.astro';

export const prerender = true;

const lang = 'en';
const title = 'Programs';
const pageTitle = 'Programs and Projects';
const description = 'Programs and projects of PA Counterpart-Sheriktesh';

const programs = (await getCollection('programs', (p) => p.data.lang === lang))
  .sort((a, b) => a.data.order - b.data.order);

const excerpt = (body: string) => {
  const clean = body.replace(/[#*_`>]/g, '').replace(/\s+/g, ' ').trim();
  return clean.length > 150 ? `${clean.slice(0, 150).trim()}…` : clean;
};
---

<PageLayout title={title} lang={lang} pageTitle={pageTitle} description={description}>
  <p>The Public Association «Counterpart-Sheriktesh» implements the following programs and projects:</p>

  <div class="program-grid">
    {programs.map((prog, i) => (
      <div class="program-card">
        <span class="num">{String(i + 1).padStart(2, '0')}</span>
        <h3>{prog.data.title}</h3>
        <p>{excerpt(prog.body)}</p>
        <a class="read-more" href={`/en/programs/prog${prog.data.order}/`}>Read more →</a>
      </div>
    ))}
  </div>
</PageLayout>
