---
import PageLayout from '../../../layouts/PageLayout.astro';

export const prerender = true;

const lang = 'en';
const title = 'Environmental Initiatives';
const pageTitle = 'Program 7: Environmental Initiatives';
---

<PageLayout title={title} lang={lang} pageTitle={pageTitle}>
  <p>The environmental initiatives program is aimed at protecting the environment and promoting the principles of sustainable development in Kyrgyzstan.</p>
  <p>The organization conducts environmental monitoring, implements projects on territory cleanup, landscaping, and promotion of environmentally responsible behavior.</p>
  <p>Special attention is paid to environmental safety issues and the impact of industrial facilities on public health.</p>
</PageLayout>
