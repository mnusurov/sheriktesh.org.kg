---
import PageLayout from '../../../layouts/PageLayout.astro';

export const prerender = true;

const lang = 'en';
const title = 'Youth Programs';
const pageTitle = 'Program 9: Youth Programs';
---

<PageLayout title={title} lang={lang} pageTitle={pageTitle}>
  <p>Youth programs are aimed at developing the potential of young people and their active participation in public life.</p>
  <p>The program implements projects on non-formal education, leadership development, volunteering and civic engagement of youth.</p>
  <p>The organization creates platforms for dialogue between youth and representatives of state bodies and civil society.</p>
</PageLayout>
