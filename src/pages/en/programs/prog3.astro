---
import PageLayout from '../../../layouts/PageLayout.astro';

export const prerender = true;

const lang = 'en';
const title = 'Community Development';
const pageTitle = 'Program 3: Community Development';
---

<PageLayout title={title} lang={lang} pageTitle={pageTitle}>
  <p>The community development program is aimed at supporting citizen initiatives at the local level.</p>
  <p>The organization provides consulting and methodological assistance to local communities in solving socially significant problems, developing infrastructure and improving quality of life.</p>
  <p>The program promotes the development of self-government and civic activity at the local level.</p>
</PageLayout>
