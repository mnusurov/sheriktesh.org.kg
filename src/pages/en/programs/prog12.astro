---
import PageLayout from '../../../layouts/PageLayout.astro';

export const prerender = true;

const lang = 'en';
const title = 'Peacebuilding Initiatives';
const pageTitle = 'Program 12: Peacebuilding Initiatives';
---

<PageLayout title={title} lang={lang} pageTitle={pageTitle}>
  <p>Peacebuilding initiatives are aimed at conflict prevention and strengthening interethnic harmony in Kyrgyzstan.</p>
  <p>The organization implements projects on mediation, building dialogue between various population groups, promoting a culture of peace and tolerance.</p>
  <p>Trainings on peaceful conflict resolution are conducted, intercultural exchanges and dialogue platforms are organized.</p>
</PageLayout>
