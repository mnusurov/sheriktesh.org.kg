---
import PageLayout from '../../../layouts/PageLayout.astro';

export const prerender = true;

const lang = 'en';
const title = 'Legal Education';
const pageTitle = 'Program 2: Legal Education';
---

<PageLayout title={title} lang={lang} pageTitle={pageTitle}>
  <p>The legal education program is aimed at improving legal literacy of the population of Kyrgyzstan.</p>
  <p>The program conducts seminars, trainings, and information campaigns on various aspects of legislation, rights and obligations of citizens.</p>
  <p>Special attention is paid to education of vulnerable groups and residents of remote regions.</p>
</PageLayout>
