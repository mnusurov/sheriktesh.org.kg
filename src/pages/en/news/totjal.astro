---
import PageLayout from '../../../layouts/PageLayout.astro';

export const prerender = true;

const lang = 'en';
const title = 'ToT Jalalabad';
const pageTitle = 'Training of Trainers — Jalalabad';
---

<PageLayout title={title} lang={lang} pageTitle={pageTitle}>
  <p><strong>Date:</strong> 2024</p>
  <p><strong>Location:</strong> Jalalabad city</p>
  <p>The Public Association «Counterpart-Sheriktesh» conducted a Training of Trainers (ToT) in Jalalabad city. The training was aimed at preparing specialists capable of conducting educational programs on human rights in the regions.</p>
  <p>Participants learned modern teaching methods, gained knowledge of international human rights standards and learned to develop educational modules.</p>
  <p>Upon completion of the training, participants received certificates and teaching materials for conducting their own classes.</p>
</PageLayout>
