---
import PageLayout from '../../../layouts/PageLayout.astro';

export const prerender = true;

const lang = 'en';
const title = 'Press Conference';
const pageTitle = 'Press Conference';
---

<PageLayout title={title} lang={lang} pageTitle={pageTitle}>
  <p><strong>Date:</strong> 2024</p>
  <p>The Public Association «Counterpart-Sheriktesh» held a press conference dedicated to the results of human rights monitoring in Kyrgyzstan.</p>
  <p>The press conference presented the results of the organization's research work, highlighted the main problems and recommendations for improving the situation in the field of human rights.</p>
  <p>The event was attended by representatives of state bodies, international organizations, NGOs and media.</p>
</PageLayout>
