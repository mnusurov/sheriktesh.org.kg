---
import PageLayout from '../../../layouts/PageLayout.astro';

export const prerender = true;

const lang = 'en';
const title = 'ToT Bishkek';
const pageTitle = 'Training of Trainers — Bishkek';
---

<PageLayout title={title} lang={lang} pageTitle={pageTitle}>
  <p><strong>Date:</strong> 2024</p>
  <p><strong>Location:</strong> Bishkek city</p>
  <p>The Public Association «Counterpart-Sheriktesh» conducted a Training of Trainers (ToT) in Bishkek city. The event brought together participants from various regions of Kyrgyzstan.</p>
  <p>The training program included modules on human rights, teaching methodology, evaluation of educational programs effectiveness and development of trainer skills.</p>
  <p>The training was an important step in creating a network of trained human rights trainers in Kyrgyzstan.</p>
</PageLayout>
