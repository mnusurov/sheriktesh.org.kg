---
import PageLayout from '../../../layouts/PageLayout.astro';

export const prerender = true;

const lang = 'en';
const title = 'Media Competition';
const pageTitle = 'Media Competition for Journalists';
---

<PageLayout title={title} lang={lang} pageTitle={pageTitle}>
  <p><strong>Date:</strong> 2024</p>
  <p>The Public Association «Counterpart-Sheriktesh» held a media competition for journalists on the best coverage of human rights topics in the media.</p>
  <p>The purpose of the competition is to attract media attention to human rights issues, improve the quality of journalistic materials on human rights topics, and encourage professional journalists.</p>
  <p>Journalists from various regions of Kyrgyzstan took part in the competition. Winners were determined in several categories.</p>
</PageLayout>
