---
import { getCollection } from 'astro:content';
import PageLayout from '../../../layouts/PageLayout.astro';

export const prerender = true;

const lang = 'en';
const title = 'News';
const pageTitle = 'News';
const description = 'News of PA Counterpart-Sheriktesh';

const news = (await getCollection('news', (n) => n.data.lang === lang))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const excerpt = (body: string) => {
  const clean = body
    .replace(/^\s*\*\*[^\n]+\*\*\s*\n+/, '')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/[#*_`>]/g, '')
    .replace(/\s+/g, ' ')
    .trim();
  return clean.length > 160 ? `${clean.slice(0, 160).trim()}…` : clean;
};

const formatDate = (d: string) =>
  new Date(d).toLocaleDateString('en-US', { day: 'numeric', month: 'short', year: 'numeric' });
---

<PageLayout title={title} lang={lang} pageTitle={pageTitle} description={description}>
  <div class="news-list">
    {news.map((n) => (
      <article class="news-item">
        <div class="news-date">{formatDate(n.data.date)}</div>
        <h3><a href={`/en/news/${n.id.replace(/^(ru|en)\//, '').replace(/\.md$/, '')}/`}>{n.data.title}</a></h3>
        <p>{n.data.description || excerpt(n.body)}</p>
      </article>
    ))}
  </div>
</PageLayout>
