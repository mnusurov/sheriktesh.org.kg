---
import { getCollection } from 'astro:content'
import PageLayout from '@/layouts/PageLayout.astro'

export const prerender = true;

const lang = 'ru';
const page = await getCollection('partners', ({ slug }) => slug === 'ru/localngo')
const { data } = page[0]
const { Content } = await page[0]!.render()
---

<PageLayout title={data.title} lang={lang} pageTitle={data.title}>
  <article class="page-content">
    <Content />
  </article>
</PageLayout>
