---
import PageLayout from '../../../layouts/PageLayout.astro';

export const prerender = true;

const lang = 'ru';
const title = 'Штат';
const pageTitle = 'Штат';
const description = 'Штат сотрудников ОО Каунтерпарт-Шериктеш';
---

<PageLayout title={title} lang={lang} pageTitle={pageTitle} description={description}>
  <div class="staff-grid">
  <div class="staff-card">
    <div class="staff-photo-placeholder" style="width:80px;height:106px;background:var(--border);border-radius:6px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:2rem;color:var(--text-light);">?</div>
    <div>
      <div class="staff-name">Нурдин Саттаров</div>
      <div class="staff-role">Исполнительный директор</div>
    </div>
  </div>
  <div class="staff-card">
    <img src="/assets/foto/meerim.jpg" alt="Мээрим Сарыкуева">
    <div>
      <div class="staff-name">Мээрим Сарыкуева</div>
      <div class="staff-role">Финансовый менеджер</div>
    </div>
  </div>
  <div class="staff-card">
    <img src="/assets/foto/asel.jpg" alt="Асель Кекебаева">
    <div>
      <div class="staff-name">Асель Кекебаева</div>
      <div class="staff-role">Координатор программ</div>
    </div>
  </div>
  </div>
</PageLayout>
