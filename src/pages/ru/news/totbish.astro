---
import PageLayout from '../../../layouts/PageLayout.astro';

export const prerender = true;

const lang = 'ru';
const title = 'ТОТ Бишкек';
const pageTitle = 'Тренинг для тренеров — Бишкек';
---

<PageLayout title={title} lang={lang} pageTitle={pageTitle}>
  <p><strong>Дата:</strong> 2024</p>
  <p><strong>Место проведения:</strong> г. Бишкек</p>
  <p>Общественное объединение «Каунтерпарт-Шериктеш» провел тренинг для тренеров (ТОТ) в городе Бишкек. Мероприятие собрало участников из различных регионов Кыргызстана.</p>
  <p>Программа тренинга включала модули по правам человека, методологии обучения, оценке эффективности образовательных программ и развитию тренерских навыков.</p>
  <p>Тренинг стал важным шагом в создании сети подготовленных тренеров по правам человека в Кыргызстане.</p>
</PageLayout>
