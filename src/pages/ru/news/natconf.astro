---
import PageLayout from '../../../layouts/PageLayout.astro';

export const prerender = true;

const lang = 'ru';
const title = 'Национальная конференция';
const pageTitle = 'Национальная конференция по правам человека';
---

<PageLayout title={title} lang={lang} pageTitle={pageTitle}>
  <p><strong>Дата:</strong> 2024</p>
  <p>Общественное объединение «Каунтерпарт-Шериктеш» организовал Национальную конференцию по вопросам прав человека в Кыргызской Республике.</p>
  <p>Конференция собрала представителей государственных органов, международных организаций, неправительственных организаций, научного сообщества и СМИ для обсуждения актуальных вопросов в сфере прав человека.</p>
  <p>В ходе конференции были обсуждены следующие темы:</p>
  <ul>
    <li>Состояние прав человека в Кыргызстане</li>
    <li>Роль гражданского общества в защите прав человека</li>
    <li>Международные стандарты и национальное законодательство</li>
    <li>Права уязвимых групп населения</li>
  </ul>
</PageLayout>
