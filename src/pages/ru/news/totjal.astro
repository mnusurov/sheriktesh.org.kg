---
import PageLayout from '../../../layouts/PageLayout.astro';

export const prerender = true;

const lang = 'ru';
const title = 'ТОТ Жалалабад';
const pageTitle = 'Тренинг для тренеров — Жалалабад';
---

<PageLayout title={title} lang={lang} pageTitle={pageTitle}>
  <p><strong>Дата:</strong> 2024</p>
  <p><strong>Место проведения:</strong> г. Жалалабад</p>
  <p>Общественное объединение «Каунтерпарт-Шериктеш» провел тренинг для тренеров (ТОТ) в городе Жалалабад. Обучение было направлено на подготовку специалистов, способных проводить образовательные программы по правам человека в регионах.</p>
  <p>Участники тренинга освоили современные методики преподавания, получили знания по международным стандартам в области прав человека и научились разрабатывать образовательные модули.</p>
  <p>По окончании тренинга участники получили сертификаты и методические материалы для самостоятельного проведения занятий.</p>
</PageLayout>
