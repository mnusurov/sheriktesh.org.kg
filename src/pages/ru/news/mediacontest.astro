---
import PageLayout from '../../../layouts/PageLayout.astro';

export const prerender = true;

const lang = 'ru';
const title = 'Медиа-конкурс';
const pageTitle = 'Медиа-конкурс среди журналистов';
---

<PageLayout title={title} lang={lang} pageTitle={pageTitle}>
  <p><strong>Дата:</strong> 2024</p>
  <p>Общественное объединение «Каунтерпарт-Шериктеш» провел медиа-конкурс среди журналистов на лучшее освещение правозащитной тематики в средствах массовой информации.</p>
  <p>Цель конкурса — привлечение внимания СМИ к вопросам защиты прав человека, повышение качества журналистских материалов на правозащитную тематику и поощрение профессиональных журналистов.</p>
  <p>В конкурсе приняли участие журналисты из различных регионов Кыргызстана. Победители были определены в нескольких номинациях.</p>
</PageLayout>
