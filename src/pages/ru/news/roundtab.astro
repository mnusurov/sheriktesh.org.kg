---
import PageLayout from '../../../layouts/PageLayout.astro';

export const prerender = true;

const lang = 'ru';
const title = 'Круглые столы';
const pageTitle = 'Круглые столы по развитию гражданского общества';
---

<PageLayout title={title} lang={lang} pageTitle={pageTitle}>
  <p><strong>Дата:</strong> 2024</p>
  <p>Общественное объединение «Каунтерпарт-Шериктеш» провел серию круглых столов по актуальным вопросам развития гражданского общества в Кыргызстане.</p>
  <p>Круглые столы были посвящены следующим темам:</p>
  <ul>
    <li>Участие гражданского общества в принятии государственных решений</li>
    <li>Прозрачность и подотчетность государственных органов</li>
    <li>Механизмы общественного контроля</li>
    <li>Развитие волонтерства и благотворительности</li>
  </ul>
  <p>В мероприятиях приняли участие представители НПО, государственных органов, международных организаций и активные граждане.</p>
</PageLayout>
