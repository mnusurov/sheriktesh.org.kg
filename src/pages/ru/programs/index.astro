---
import { getCollection } from 'astro:content';
import PageLayout from '../../../layouts/PageLayout.astro';

export const prerender = true;

const lang = 'ru';
const title = 'Программы';
const pageTitle = 'Программы и проекты';
const description = 'Программы и проекты ОО Каунтерпарт-Шериктеш';

const programs = (await getCollection('programs', (p) => p.data.lang === lang))
  .sort((a, b) => a.data.order - b.data.order);

const excerpt = (body: string) => {
  const clean = body.replace(/[#*_`>]/g, '').replace(/\s+/g, ' ').trim();
  return clean.length > 150 ? `${clean.slice(0, 150).trim()}…` : clean;
};
---

<PageLayout title={title} lang={lang} pageTitle={pageTitle} description={description}>
  <p>Общественное объединение «Каунтерпарт-Шериктеш» реализует следующие программы и проекты:</p>

  <div class="program-grid">
    {programs.map((prog, i) => (
      <div class="program-card">
        <span class="num">{String(i + 1).padStart(2, '0')}</span>
        <h3>{prog.data.title}</h3>
        <p>{prog.data.description || excerpt(prog.body)}</p>
        <a class="read-more" href={`/ru/programs/prog${prog.data.order}`}>Подробнее →</a>
      </div>
    ))}
  </div>
</PageLayout>
