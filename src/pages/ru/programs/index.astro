---
import { getCollection } from 'astro:content';
import PageLayout from '../../../layouts/PageLayout.astro';

export const prerender = true;

const lang = 'ru';
const title = 'Программы';
const pageTitle = 'Программы и проекты';

const programs = (await getCollection('programs', (p) => p.data.lang === lang))
  .sort((a, b) => a.data.order - b.data.order);
---

<PageLayout title={title} lang={lang} pageTitle={pageTitle}>
  <p>Общественное объединение «Каунтерпарт-Шериктеш» реализует следующие программы и проекты:</p>

  <ul>
    {programs.map((p) => (
      <li><a href={`/ru/programs/prog${p.data.order}/`}>{p.data.title}</a></li>
    ))}
  </ul>
</PageLayout>
