---
import PageLayout from '../../../layouts/PageLayout.astro';

export const prerender = true;

const lang = 'ru';
const title = 'Развитие СМИ';
const pageTitle = 'Программа 13: Развитие независимых СМИ';
---

<PageLayout title={title} lang={lang} pageTitle={pageTitle}>
  <p>Программа развития независимых СМИ направлена на поддержку свободы слова и развитие независимой журналистики в Кыргызстане.</p>
  <p>Организация проводит тренинги для журналистов, оказывает правовую поддержку представителям СМИ, способствует созданию профессиональных стандартов журналистики.</p>
  <p>Реализуются проекты по защите прав журналистов и развитию цифровых медиа.</p>
</PageLayout>
