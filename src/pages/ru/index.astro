---
import { getCollection } from 'astro:content'
import BaseLayout from '@/layouts/BaseLayout.astro'
import SidebarWidget from '@/components/SidebarWidget.astro'

export const prerender = true;

const lang = 'ru';
const blocks = (await getCollection("homepage", ({ data }) => data.lang === lang))
  .sort((a, b) => a.data.order - b.data.order)

const rendered = await Promise.all(
  blocks.map(async (entry) => {
    const { Content } = await entry.render()
    return { data: entry.data, Content }
  })
)

const yearsActive = new Date().getFullYear() - 2002;
const programsCount = (await getCollection('programs', (p) => p.data.lang === lang)).length;

const pluralYears = (n: number) => {
  const mod100 = n % 100;
  const mod10 = n % 10;
  if (mod100 >= 11 && mod100 <= 14) return 'лет';
  if (mod10 === 1) return 'год';
  if (mod10 >= 2 && mod10 <= 4) return 'года';
  return 'лет';
};
---

<BaseLayout title="Главная" lang={lang}>
  {rendered.filter(({ data }) => data.block_type === 'hero').map(({ Content }) => (
    <section class="hero">
      <div class="container">
        <h1>Общественное объединение «Каунтерпарт-Шериктеш»</h1>
        <Content />
      </div>
    </section>
  ))}
  <section class="stats">
    <div class="container">
      <div class="stats-grid">
        <div class="stat">
          <span class="stat-num">{yearsActive}</span>
          <span class="stat-label">{pluralYears(yearsActive)} работы</span>
        </div>
        <div class="stat">
          <span class="stat-num">{programsCount}</span>
          <span class="stat-label">программ и проектов</span>
        </div>
      </div>
    </div>
  </section>
  <main class="content">
    <div class="container">
      <div class="content-wrap">
        <div class="content-main">
          {rendered.filter(({ data }) => data.block_type !== 'hero').map(({ data, Content }) => (
            <section class={`${data.block_type}-section`}>
              <h2>{data.title}</h2>
              <Content />
            </section>
          ))}
        </div>
        <aside class="content-sidebar">
          <SidebarWidget lang={lang} />
        </aside>
      </div>
    </div>
  </main>
</BaseLayout>
