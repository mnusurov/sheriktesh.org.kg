---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SidebarWidget from '../../components/SidebarWidget.astro';

export const prerender = true;

const lang = 'ru';
const title = 'Главная';
const description = 'Общественное объединение Каунтерпарт-Шериктеш — содействие развитию гражданского общества и защита прав человека в Кыргызстане';
---

<BaseLayout title={title} lang={lang} description={description}>
  <main class="content">
    <div class="container">
      <div class="content-wrap">
        <div class="content-main">
          <section class="hero">
            <h1>Общественное объединение «Каунтерпарт-Шериктеш»</h1>
            <p class="hero-subtitle">Содействие развитию гражданского общества и защита прав человека в Кыргызстане</p>
          </section>

          <p><strong>В 2026 году организации исполнилось 24 года!</strong></p>
          <p>Общественное Объединение "Каунтерпарт-Шериктеш" является зарегистрированным НПО, образованным активистами гражданского общества с целью повышения потенциала организаций гражданского общества в Кыргызстане. С самого начала поддержка ОО "Каунтерпарт-Шериктеш" по повышению потенциала НПО включала проведение тренингов по основным модулям, предоставление консультаций по организационному развитию и стимулированию обмена информацией между НПО и общественными организациями. ОО "Каунтерпарт-Шериктеш" постепенно расширяло свои услуги и активно участвовало в процессе усиления участия гражданского общества в принятии решений и повышения потенциала НПО, предоставляя им новые модули тренингов, новые услуги (эдвокаси, усиление социального партнёрства и т.д.) и расширяя свою клиентскую базу. ОО "Каунтерпарт-Шериктеш" принимало участие в разработке Национальной стратегии сокращения бедности: две части, описывающие процедуры всеобщего участия и роль НПО в реализации данной стратегии были разработаны сотрудниками ОО "Каунтерпарт-Шериктеш".</p>

          <section class="about-section">
            <h2>О нас</h2>
            <p>Общественное объединение «Каунтерпарт-Шериктеш» основано в январе 2002 года. Организация работает в сфере укрепления гражданского общества, защиты прав человека и демократического развития Кыргызской Республики.</p>
            <p>Наша миссия — содействие построению демократического, правового государства, развитие институтов гражданского общества, защита прав и свобод человека и гражданина.</p>
            <p>За годы работы мы реализовали десятки проектов, направленных на мониторинг соблюдения прав человека, правовое просвещение населения, развитие местных сообществ и укрепление демократических институтов.</p>
          </section>

          <section class="activities-section">
            <h2>Основные направления деятельности</h2>
            <ul>
              <li>Мониторинг соблюдения прав человека</li>
              <li>Правовое просвещение и образование</li>
              <li>Развитие гражданского общества</li>
              <li>Защита прав уязвимых групп населения</li>
              <li>Экологический мониторинг и защита окружающей среды</li>
            </ul>
          </section>
        </div>
        <aside class="content-sidebar">
          <SidebarWidget lang={lang} />
        </aside>
      </div>
    </div>
  </main>
</BaseLayout>
