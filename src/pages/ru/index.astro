---
import { getCollection } from 'astro:content'
import BaseLayout from '@/layouts/BaseLayout.astro'
import SidebarWidget from '@/components/SidebarWidget.astro'

export const prerender = true;

const lang = 'ru';
const blocks = (await getCollection("homepage", ({ data }) => data.lang === lang))
  .sort((a, b) => a.data.order - b.data.order)

const rendered = await Promise.all(
  blocks.map(async (entry) => {
    const { Content } = await entry.render()
    return { data: entry.data, Content }
  })
)
---

<BaseLayout title="Главная" lang={lang}>
  <main class="content">
    <div class="container">
      <div class="content-wrap">
        <div class="content-main">
          {rendered.map(({ data, Content }) =>
            data.block_type === 'hero' ? (
              <section class="hero">
                <h1>Общественное объединение «Каунтерпарт-Шериктеш»</h1>
                <Content />
              </section>
            ) : (
              <section class={`${data.block_type}-section`}>
                <h2>{data.title}</h2>
                <Content />
              </section>
            )
          )}
        </div>
        <aside class="content-sidebar">
          <SidebarWidget lang={lang} />
        </aside>
      </div>
    </div>
  </main>
</BaseLayout>
