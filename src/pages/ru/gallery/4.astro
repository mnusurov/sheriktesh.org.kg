---
import PageLayout from '../../../layouts/PageLayout.astro';

export const prerender = true;

const lang = 'ru';
const title = 'Заключительный круглый стол по проекту АКДН';
const pageTitle = 'Заключительный круглый стол по проекту АКДН';
---

<PageLayout title={title} lang={lang} pageTitle={pageTitle}>
  <div class="gallery-grid">
    <img src="/assets/foto/conf1.jpg" alt="Конференция 1" />
    <img src="/assets/foto/conf2.jpg" alt="Конференция 2" />
    <img src="/assets/foto/conf3.jpg" alt="Конференция 3" />
  </div>
</PageLayout>
