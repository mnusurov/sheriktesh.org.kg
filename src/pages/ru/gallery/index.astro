---
import { getCollection } from 'astro:content';
import PageLayout from '../../../layouts/PageLayout.astro';

export const prerender = true;

const lang = 'ru';
const title = 'Фотогалерея';
const pageTitle = 'Фотогалерея';
const description = 'Фотогалерея ОО Каунтерпарт-Шериктеш';

const galleries = (await getCollection('galleries', (g) => g.data.lang === lang))
  .sort((a, b) => a.data.order - b.data.order);
---

<PageLayout title={title} lang={lang} pageTitle={pageTitle} description={description}>
  <p>Фотографии мероприятий и проектов организации.</p>

  <div class="gallery-card-grid">
    {galleries.map((g) => (
      <a class="gallery-card" href={`/ru/gallery/${g.data.order}`}>
        <img class="gallery-card-thumb" src={g.data.images[0]} alt="" />
        <div class="gallery-card-body">
          <h3>{g.data.title}</h3>
          <span class="gallery-card-count">{g.data.images.length} фото</span>
        </div>
      </a>
    ))}
  </div>
</PageLayout>
