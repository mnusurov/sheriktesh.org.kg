---
import PageLayout from '../../../layouts/PageLayout.astro';

export const prerender = true;

const lang = 'ru';
const title = 'Национальная конференция по социальному партнёрству';
const pageTitle = 'Национальная конференция по социальному партнёрству';
---

<PageLayout title={title} lang={lang} pageTitle={pageTitle}>
  <div class="gallery-grid">
    <img src="/assets/foto/event1.jpg" alt="Мероприятие 1" />
    <img src="/assets/foto/event2.jpg" alt="Мероприятие 2" />
    <img src="/assets/foto/event3.jpg" alt="Мероприятие 3" />
  </div>
</PageLayout>
