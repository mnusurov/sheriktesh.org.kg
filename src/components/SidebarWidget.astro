---
export interface GalleryItem {
  src: string;
  href: string;
}

export interface Props {
  lang: 'ru' | 'en';
  items?: GalleryItem[];
}

const { lang } = Astro.props;
const p = lang === 'ru' ? '/ru' : '/en';

const galleryItems = Astro.props.items ?? [
  { src: '/assets/foto/wshop-bi1_thumb.jpg', href: `${p}/gallery/2` },
  { src: '/assets/foto/agakhan-conf4_thumb.jpg', href: `${p}/gallery/1` },
  { src: '/assets/foto/wshop-ja4_thumb.jpg', href: `${p}/gallery/3` },
];

const maxItems = galleryItems.slice(0, 3);
const galleryLink = `${p}/gallery`;
---

<div class="card sidebar-gallery">
  <h3>{lang === 'ru' ? 'Фотогалерея' : 'Photo Gallery'}</h3>
  {maxItems.map((item) => (
    <a href={item.href} class="sidebar-gallery-thumb">
      <img src={item.src} alt="" />
    </a>
  ))}
  <a href={galleryLink} class="sidebar-gallery-link">
    {lang === 'ru' ? 'Все фотогалереи' : 'All galleries'}
  </a>
</div>

<style>
  .sidebar-gallery {
    background: var(--cream);
    border: none;
  }
  .sidebar-gallery-thumb {
    display: block;
    margin-bottom: 0.75rem;
    overflow: hidden;
  }
  .sidebar-gallery-thumb img {
    width: 100%;
    display: block;
    filter: grayscale(20%) sepia(8%);
    transition: transform 0.5s cubic-bezier(0.16,1,0.3,1), filter 0.3s ease;
  }
  .sidebar-gallery-thumb:hover img {
    transform: scale(1.08);
    filter: grayscale(0%) sepia(0%);
  }
  .sidebar-gallery-link {
    display: inline-block;
    color: var(--terracotta) !important;
    font-weight: 600;
    font-size: 0.85rem;
    border-bottom: 1px solid var(--terracotta);
  }
</style>
